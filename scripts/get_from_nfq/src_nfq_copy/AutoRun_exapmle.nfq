#####
##### ON,データベースの接続
#####
CONNECT FINFST;NOTFOUND NOVALUE;SELECTKEY STKNO;SETSUBKEY 1:SCSECSUB = {C0},2:TYSUB = {Y1,Y2},3:BASESUB = {B0};RESET TARGET;
#####
##### ON,TARGETの送信
#####
RESET TARGET;NOTFOUND NOVALUE;TARGET $TARGET,((T1301));
#####
##### ON,レポート出力及び、X12出力オプション
#####
!SELECT HEADER 0,LANGUAGE 1,UNIT OFF,CHECKREPORTINFO ON,INFOSHEET ON;
#####
##### ON,レポートコマンド送信
#####
